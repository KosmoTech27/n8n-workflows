    {
      "parameters": {
        "jsCode": "const p = $('Parse Input').item.json;\nconst ev = $('Create Event').item.json;\nconst d = new Date(p.start_iso);\nconst opts = { timeZone:'Asia/Kolkata', weekday:'long', month:'long', day:'numeric', hour:'numeric', minute:'2-digit', hour12:true };\nconst whenSpoken = new Intl.DateTimeFormat('en-IN', opts).format(d);\nconst code = (ev.id || '').slice(-6).toUpperCase();\nreturn [{ json: { booked:true, confirmation_code: code, when_spoken: whenSpoken, calendar_event_id: ev.id, call_id: p.call_id } }];"
      },
