    {
      "parameters": {
        "jsCode": "const p = $('Parse Input').item.json;\nconst fb = $input.first().json;\nconst cal = (fb.calendars || {})[p.cal_id] || {};\nconst busy = cal.busy || [];\nreturn [{ json: Object.assign({}, p, { still_free: busy.length === 0 }) }];"
      },
