    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst start = new Date(body.start_iso);\nif (isNaN(start.getTime())) return [{ json: { error:'bad_iso', got: body.start_iso } }];\nconst duration = parseInt(body.duration_minutes || '30', 10);\nconst end = new Date(start.getTime() + duration*60000);\nconst bufferMin = 10;\nconst windowStart = new Date(start.getTime() - bufferMin*60000).toISOString();\nconst windowEnd = new Date(end.getTime() + bufferMin*60000).toISOString();\nconst calId = '9e31eddd03011a49802170cdb7228dd24099675b0bd216060ba080d93e714e42@group.calendar.google.com';\nconst sheetId = '1xvbM37zAPLflfjLn66tWv0jGiFpSrrBILM-drdW0Da0';\nreturn [{ json: {\n  call_id: body.call_id || '',\n  caller_name: body.caller_name || '',\n  caller_phone: body.caller_phone || '',\n  service: body.service || 'Consultation',\n  notes: body.notes || '',\n  start_iso: start.toISOString(),\n  end_iso: end.toISOString(),\n  duration_minutes: duration,\n  window_start: windowStart,\n  window_end: windowEnd,\n  cal_id: calId,\n  sheet_id: sheetId\n}}];"
      },
      "id": "parse",
      "name": "Parse Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        300
      ]
    },
    {
